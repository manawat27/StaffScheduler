{
  "realm": "staff-scheduler",
  "enabled": true,
  "organizationsEnabled": true,
  "registrationAllowed": true,
  "verifyEmail": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "registrationEmailAsUsername": false,
  "sslRequired": "none",
  "loginTheme": "staff-scheduler-theme",
  "attributes": {
    "pkce.code.challenge.method": "S256",
    "post.logout.redirect.uris": "staff-scheduler://logout"
  },
  "clients": [
    {
      "clientId": "staff-scheduler",
      "name": "staff-scheduler Client",
      "publicClient": true,
      "protocol": "openid-connect",
      "redirectUris": [
        "http://buildops.salussystems.com/*",
        "http://174.138.114.79/*",
        "http://frontend:3000/*",
        "http://localhost:3000/*",
        "staff-scheduler://oauthredirect",
        "staff-scheduler://*",
        "http://localhost:8081/*",
        "*"
      ],
      "webOrigins": [
        "http://buildops.salussystems.com",
        "http://174.138.114.79",
        "http://frontend:3000",
        "http://localhost:3000",
        "*",
        "http://localhost:3000",
        "http://localhost:3000/*",
        "http://frontend:3000/*",
        "staff-scheduler://oauthredirect",
        "http://localhost:8081",
        "http://localhost:8081/*",
        "http://localhost:8081/oauthredirect",
        "http://127.0.0.1:3000",
        "http://127.0.0.1:3000/*",
        "http://127.0.0.1:8081",
        "http://127.0.0.1:8081/*",
        "http://127.0.0.1:8081/oauthredirect",
        "http://127.0.0.1:3000",
        "http://127.0.0.1:8081",
        "http://localhost:3000",
        "http://localhost:8081"
      ],
      "standardFlowEnabled": true,
      "attributes": {
        "pkce.code.challenge.method": ""
      },
      "protocolMappers": [
        {
          "name": "audience-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "buildops",
            "id.token.claim": "true",
            "access.token.claim": "true"
          }
        },
        {
          "name": "organization",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-organization-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "organization",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "organization",
            "introspection.token.claim": "true",
            "jsonType.label": "JSON",
            "multivalued": "true",
            "lightweight.claim": false,
            "userinfo.token.claim": "true",
            "addOrganizationAttributes": "true",
            "addOrganizationId": "true"
          }
        }
      ],
      "defaultClientScopes": [
        "web-origins",
        "acr",
        "profile",
        "roles",
        "organization",
        "basic",
        "email"
      ]
    }
  ],
  "roles": {
    "realm": [{ "name": "admin" }, { "name": "manager" }, { "name": "staff" }]
  },
